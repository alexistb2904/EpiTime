{
	"name": "epitime-native-front",
	"version": "1.1.0",
	"private": true,
	"main": "index.ts",
	"scripts": {
		"start": "npx expo start",
		"android": "npx expo run:android",
		"ios": "npx expo run:ios",
		"prebuild": "npx expo prebuild",
		"apk": "npm run apk:build && npm run apk:copy",
		"apkLinux": "npm run apkLinux:build && npm run apk:copy",
		"apk:build": "set \"NODE_ENV=production\" && set \"JAVA_HOME=C:\\Program Files\\Android\\Android Studio\\jbr\" && set \"PATH=%JAVA_HOME%\\bin;%PATH%\" && cd android && gradlew.bat assembleRelease",
		"apkLinux:build": "cd android && NODE_ENV=production ./gradlew assembleRelease",
		"apk:clean": "cd android && gradlew.bat clean",
		"apk:copy": "node -e \"const fs=require('fs'); const pkg=require('./package.json'); fs.copyFileSync('android/app/build/outputs/apk/release/app-release.apk', `EpiTime-${pkg.version}-release.apk`); console.log(`APK copied to EpiTime-${pkg.version}-release.apk`);\"",
		"apk:rebuild": "npm run apk:clean && npm run apk",
		"build:android": "eas build -p android",
		"build:ios": "eas build -p ios"
	},
	"dependencies": {
		"@pchmn/expo-material3-theme": "^1.4.0",
		"@react-native-async-storage/async-storage": "3.1.0",
		"@react-navigation/bottom-tabs": "7.16.1",
		"@react-navigation/native": "7.2.4",
		"babel-preset-expo": "~56.0.0",
		"expo": "56.0.4",
		"expo-auth-session": "56.0.11",
		"expo-background-task": "~56.0.15",
		"expo-constants": "56.0.15",
		"expo-device": "56.0.4",
		"expo-linking": "56.0.11",
		"expo-notifications": "56.0.13",
		"expo-secure-store": "56.0.4",
		"expo-status-bar": "56.0.4",
		"expo-task-manager": "~56.0.15",
		"expo-web-browser": "56.0.5",
		"lucide-react-native": "1.16.0",
		"react": "19.2.3",
		"react-native": "0.85.3",
		"react-native-android-widget": "^0.20.3",
		"react-native-gesture-handler": "2.31.2",
		"react-native-reanimated": "4.3.1",
		"react-native-safe-area-context": "5.8.0",
		"react-native-screens": "4.25.2",
		"react-native-svg": "15.15.4",
		"react-native-worklets": "0.8.3"
	},
	"devDependencies": {
		"@types/react": "19.2.15",
		"typescript": "6.0.3"
	}
}
